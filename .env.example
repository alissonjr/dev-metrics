# =============================================================================
# Engineering Metrics — exemplo de configuracao
# Copie este arquivo para .env e preencha os valores antes de rodar o projeto.
# =============================================================================

# -----------------------------------------------------------------------------
# GitLab
# Personal Access Token com escopos: api, read_repository, read_user
# Gere em: https://<sua-instancia>/profile/personal_access_tokens
# (GitLab.com: https://gitlab.com/-/user_settings/personal_access_tokens)
# -----------------------------------------------------------------------------
GITLAB_URL=https://gitlab.com
GITLAB_TOKEN=
GITLAB_GROUP_ID=

# -----------------------------------------------------------------------------
# Jira
# API Token gerado em: https://id.atlassian.com/manage-profile/security/api-tokens
# JIRA_PROJECTS: chaves dos projetos separadas por virgula (ex: PROJ,DEV,OPS)
# -----------------------------------------------------------------------------
JIRA_URL=https://<sua-empresa>.atlassian.net
JIRA_EMAIL=
JIRA_TOKEN=
JIRA_PROJECTS=

# -----------------------------------------------------------------------------
# PostgreSQL (valores padrao funcionam para uso local)
# -----------------------------------------------------------------------------
POSTGRES_USER=metrics
POSTGRES_PASSWORD=metrics
POSTGRES_DB=gitlab_metrics

# -----------------------------------------------------------------------------
# ETL — comportamento da coleta
# -----------------------------------------------------------------------------
SYNC_INTERVAL_HOURS=6
JIRA_SYNC_INTERVAL_HOURS=4
HISTORY_DAYS=365
LOG_LEVEL=INFO

# Campo de story points no Jira (padrao cloud: story_points; legado: customfield_10016)
JIRA_STORY_POINTS_FIELD=story_points

# Categorias de status que contam como action time
JIRA_ACTIVE_CATEGORIES=indeterminate

# -----------------------------------------------------------------------------
# Grafana — acesse http://localhost:3000
# Recomendado: troque as credenciais na primeira execucao.
# -----------------------------------------------------------------------------
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=admin
