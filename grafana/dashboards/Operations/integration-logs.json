      "title": "Histórico de Execuções",
      "type": "table",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "gitlab-metrics"
          },
          "editorMode": "code",
          "format": "table",
          "rawQuery": true,
          "rawSql": "SELECT\n  started_at,\n  finished_at,\n  source,\n  status,\n  rows_synced,\n  errors_count,\n  since_cursor,\n  ROUND(EXTRACT(EPOCH FROM (finished_at - started_at))::numeric, 1) AS elapsed_s,\n  details\nFROM integration_sync_runs\nWHERE started_at >= $__timeFrom()\n  AND started_at <= $__timeTo()\n  AND ('${source}' = 'all' OR source = '${source}')\nORDER BY started_at DESC\nLIMIT 200",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "gitlab-metrics"
      },
      "fieldConfig": {
        "defaults": {
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "lineWidth": 2
          }
        }
      },
      "gridPos": {
        "h": 7,
        "w": 12,
        "x": 0,
        "y": 9
      },
      "id": 2,
      "options": {
        "tooltip": {
          "mode": "multi"
        }
      },
      "title": "Registros Sincronizados por Execução",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "gitlab-metrics"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  started_at AS time,\n  source,\n  rows_synced\nFROM integration_sync_runs\nWHERE started_at >= $__timeFrom()\n  AND started_at <= $__timeTo()\n  AND ('${source}' = 'all' OR source = '${source}')\n  AND (\n    '$outliers' = 'incluir'\n    OR rows_synced IS NULL\n    OR rows_synced <= (\n      SELECT PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY rows_synced)\n      FROM integration_sync_runs\n      WHERE rows_synced IS NOT NULL\n        AND started_at >= $__timeFrom() AND started_at <= $__timeTo()\n    )\n  )\n  AND (\n    '$outliers' = 'incluir'\n    OR rows_synced IS NULL\n    OR rows_synced <= (\n      SELECT PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY rows_synced)\n      FROM integration_sync_runs\n      WHERE rows_synced IS NOT NULL\n        AND started_at >= $__timeFrom() AND started_at <= $__timeTo()\n    )\n  )\nORDER BY started_at",
          "refId": "A"
        }
      ]
    },
    {
      "datasource": {
        "type": "postgres",
        "uid": "gitlab-metrics"
      },
      "fieldConfig": {
        "defaults": {
