          "rawQuery": true,
          "rawSql": "SELECT\n  created_at,\n  source,\n  level,\n  event_type,\n  project,\n  message,\n  rows_synced,\n  details\nFROM integration_logs\nWHERE created_at >= $__timeFrom()\n  AND created_at <= $__timeTo()\n  AND ('${source}' = 'all' OR source = '${source}')\n  AND ('${level}' = 'all' OR level = '${level}')\n  AND ('${event_type}' = 'all' OR event_type = '${event_type}')\nORDER BY created_at DESC\nLIMIT 500",
          "refId": "A"
