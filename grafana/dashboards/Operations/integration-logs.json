      "title": "Duração das Execuções (segundos)",
      "type": "timeseries",
      "targets": [
        {
          "datasource": {
            "type": "postgres",
            "uid": "gitlab-metrics"
          },
          "editorMode": "code",
          "format": "time_series",
          "rawQuery": true,
          "rawSql": "SELECT\n  started_at AS time,\n  source,\n  EXTRACT(EPOCH FROM (finished_at - started_at)) AS duration_s\nFROM integration_sync_runs\nWHERE started_at >= $__timeFrom()\n  AND started_at <= $__timeTo()\n  AND finished_at IS NOT NULL\n  AND ('${source}' = 'all' OR source = '${source}')\n  AND (\n    '$outliers' = 'incluir'\n    OR EXTRACT(EPOCH FROM (finished_at - started_at)) <= (\n      SELECT PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (finished_at - started_at)))\n      FROM integration_sync_runs\n      WHERE finished_at IS NOT NULL\n        AND started_at >= $__timeFrom() AND started_at <= $__timeTo()\n    )\n  )\n  AND (\n    '$outliers' = 'incluir'\n    OR EXTRACT(EPOCH FROM (finished_at - started_at)) <= (\n      SELECT PERCENTILE_CONT(0.95) WITHIN GROUP (ORDER BY EXTRACT(EPOCH FROM (finished_at - started_at)))\n      FROM integration_sync_runs\n      WHERE finished_at IS NOT NULL\n        AND started_at >= $__timeFrom() AND started_at <= $__timeTo()\n    )\n  )\nORDER BY started_at",
          "refId": "A"
        }
      ]
    },
