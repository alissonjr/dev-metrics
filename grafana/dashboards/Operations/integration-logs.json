          "rawQuery": true,
          "rawSql": "SELECT\n  date_trunc('hour', created_at) AS time,\n  level,\n  COUNT(*) AS count\nFROM integration_logs\nWHERE created_at >= $__timeFrom()\n  AND created_at <= $__timeTo()\n  AND level IN ('warning', 'error')\n  AND ('${source}' = 'all' OR source = '${source}')\nGROUP BY 1, 2\nORDER BY 1",
